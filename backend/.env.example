NODE_ENV=development
PORT=13033
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
CLIENT_ORIGIN="http://localhost:5173"
UPLOAD_MAX_SIZE_MB=15
PUBLIC_BASE_URL="http://localhost:13033"
# Reverse proxy hop count. Use 1 when Nginx/Caddy is directly in front of Node.
# You may also set TRUST_PROXY to values accepted by Express, such as "loopback".
TRUST_PROXY_HOPS=0
